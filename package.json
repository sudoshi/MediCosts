{
  "name": "medicosts",
  "private": true,
  "version": "1.0.0",
  "description": "Medicare Inpatient Hospital Pricing Dashboard",
  "scripts": {
    "dev": "node node_modules/concurrently/dist/bin/concurrently.js \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "create-db": "node scripts/create-db.js",
    "load-data": "node scripts/load-data.js",
    "download-data": "node scripts/download-datasets.js",
    "load-all": "node scripts/load-all.js",
    "create-views": "node scripts/create-cross-views.js",
    "build": "cd client && npm run build",
    "start": "npm run build && NODE_ENV=production node server/index.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
