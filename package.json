{
  "name": "medicosts",
  "private": true,
  "version": "1.0.0",
  "description": "Medicare Inpatient Hospital Pricing Dashboard",
  "scripts": {
    "dev": "node node_modules/concurrently/dist/bin/concurrently.js \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "create-db": "node scripts/create-db.js",
    "load-data": "node scripts/load-data.js",
    "download-data": "node scripts/download-datasets.js",
    "load-all": "node scripts/load-all.js",
    "create-views": "node scripts/create-cross-views.js",
    "build": "cd client && npm run build",
    "start": "npm run build && NODE_ENV=production node server/index.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.18.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "zod": "^4.3.6"
  }
}
