# PostgreSQL connection (required for load-data and API)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=medicosts

# Server (use 3090 to avoid conflicts with other apps on 3001/5173)
PORT=3090

# Auth
JWT_SECRET=<generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">
FROM_EMAIL=noreply@yourdomain.com
APP_URL=https://yourdomain.com

# Resend API key (also readable from .resendapikey file at project root)
RESEND_API_KEY=
